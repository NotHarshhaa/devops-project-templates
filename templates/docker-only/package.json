{
  "name": "docker-template-app",
  "version": "1.0.0",
  "description": "A production-ready Docker template for modern web applications",
  "main": "app/index.html",
  "scripts": {
    "start": "docker-compose up",
    "build": "docker build -t docker-template-app .",
    "dev": "docker-compose up --build",
    "stop": "docker-compose down",
    "logs": "docker-compose logs -f",
    "clean": "docker-compose down -v --rmi all",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "docker",
    "nginx",
    "web",
    "template",
    "production",
    "devops"
  ],
  "author": "DevOps Project Templates",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NotHarshhaa/devops-project-templates.git"
  },
  "bugs": {
    "url": "https://github.com/NotHarshhaa/devops-project-templates/issues"
  },
  "homepage": "https://github.com/NotHarshhaa/devops-project-templates#readme",
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
